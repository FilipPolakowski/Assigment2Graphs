#Semantic Accuracy - Identify Ontology Contstraints
#The ontology says the schema:prepTime is schema:Recipe


PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

SELECT DISTINCT ?s ?prepTime
WHERE {
  ?s <https://schema.org/prepTime> ?prepTime .
  FILTER NOT EXISTS { 
    ?s rdf:type <https://schema.org/Recipe> .
  }
}
ORDER BY ?s