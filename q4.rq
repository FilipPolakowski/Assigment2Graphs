PREFIX schema: <https://schema.org/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?recipe ?time
WHERE {
  ?recipe a schema:Recipe .
  { ?recipe schema:cookTime ?time }
  UNION
  { ?recipe schema:prepTime ?time }

  FILTER ( DATATYPE(?time) != xsd:duration )
}

# Syntactic validity
# Invalid duration data type